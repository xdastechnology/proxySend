<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="app-layout">
  <%- include('partials/sidebar') %>
  <div class="main-content">
    <%- include('partials/topbar', { pageTitle: 'Contacts', pageSubtitle: 'Manage your contact list' }) %>
    <main class="page-content">

      <% if (error) { %>
        <div class="alert alert-danger" data-auto-dismiss>
          <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success" data-auto-dismiss>
          <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
      <% } %>

      <% const safeContacts = Array.isArray(contacts) ? contacts : []; %>
      <% const activeEdit = typeof editContact !== 'undefined' ? editContact : null; %>

      <div class="two-col-sidebar">
        <!-- Left: Contact Table -->
        <div>
          <div class="card">
            <div class="card-header">
              <div>
                <h2>All Contacts</h2>
                <p><%= total %> total contacts</p>
              </div>
              <div class="flex gap-8">
                <a href="/contacts/export" class="btn btn-outline btn-sm">
                  <i class="fa-solid fa-file-export"></i> Export CSV
                </a>
                <div class="search-bar">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input
                    type="text"
                    id="contactSearch"
                    class="form-control"
                    placeholder="Search contacts..."
                    style="width:200px;"
                  />
                </div>
              </div>
            </div>

            <div class="table-container">
              <table class="table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Gender</th>
                    <th>Added</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody id="contactTableBody">
                  <% if (safeContacts.length === 0) { %>
                    <tr>
                      <td colspan="6">
                        <div class="empty-state">
                          <i class="fa-solid fa-address-book"></i>
                          <h3>No contacts yet</h3>
                          <p>Add contacts manually or import from CSV</p>
                        </div>
                      </td>
                    </tr>
                  <% } else { %>
                    <% safeContacts.forEach(contact => { %>
                      <tr>
                        <td>
                          <div class="flex-center gap-8">
                            <div class="user-avatar" style="width:28px;height:28px;flex-shrink:0;">
                              <span style="font-size:11px;"><%= contact.name.charAt(0).toUpperCase() %></span>
                            </div>
                            <span class="fw-600"><%= contact.name %></span>
                          </div>
                        </td>
                        <td><code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:13px;"><%= contact.phone %></code></td>
                        <td class="text-muted text-sm"><%= contact.email || '-' %></td>
                        <td>
                          <% if ((contact.gender || 'unspecified') === 'male') { %>
                            <span class="badge badge-info">Male</span>
                          <% } else if ((contact.gender || 'unspecified') === 'female') { %>
                            <span class="badge badge-success">Female</span>
                          <% } else if ((contact.gender || 'unspecified') === 'other') { %>
                            <span class="badge badge-warning">Other</span>
                          <% } else { %>
                            <span class="badge badge-secondary">Unspecified</span>
                          <% } %>
                        </td>
                        <td class="text-muted text-sm"><%= new Date(contact.created_at).toLocaleDateString() %></td>
                        <td>
                          <div class="flex gap-8">
                            <a href="/contacts/edit/<%= contact.id %>?page=<%= currentPage %>" class="btn btn-outline btn-sm">
                              <i class="fa-solid fa-pen"></i>
                            </a>
                            <button
                              type="button"
                              class="btn btn-danger btn-sm js-confirm-delete"
                              data-confirm-delete-url="/contacts/delete/<%= contact.id %>"
                              data-confirm-message="Delete contact <%= contact.name %>?"
                            >
                              <i class="fa-solid fa-trash"></i>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
              <div class="pagination">
                <% if (currentPage > 1) { %>
                  <a href="/contacts?page=<%= currentPage - 1 %>" class="page-link">
                    <i class="fa-solid fa-chevron-left"></i>
                  </a>
                <% } %>
                <% for(let i = 1; i <= totalPages; i++) { %>
                  <a href="/contacts?page=<%= i %>" class="page-link <%= i === currentPage ? 'active' : '' %>">
                    <%= i %>
                  </a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                  <a href="/contacts?page=<%= currentPage + 1 %>" class="page-link">
                    <i class="fa-solid fa-chevron-right"></i>
                  </a>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Right: Add / Import -->
        <div style="display:flex;flex-direction:column;gap:16px;">
          <!-- Add Contact -->
          <div class="card">
            <div class="card-header">
              <h2>
                <% if (activeEdit) { %>
                  <i class="fa-solid fa-pen" style="color:var(--warning);margin-right:6px;"></i>Edit Contact
                <% } else { %>
                  <i class="fa-solid fa-user-plus" style="color:var(--primary);margin-right:6px;"></i>Add Contact
                <% } %>
              </h2>
            </div>
            <div class="card-body">
              <form action="<%= activeEdit ? '/contacts/update/' + activeEdit.id : '/contacts/add' %>" method="POST">
                <div class="form-group">
                  <label>Full Name</label>
                  <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="John Doe"
                    value="<%= activeEdit ? activeEdit.name : '' %>"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Phone Number</label>
                  <input
                    type="text"
                    name="phone"
                    class="form-control"
                    placeholder="9876543210"
                    value="<%= activeEdit ? activeEdit.phone : '' %>"
                    required
                  />
                  <p class="form-hint">If number does not start with 91, 91 is added automatically. Only WhatsApp-registered numbers are accepted.</p>
                </div>
                <div class="form-group">
                  <label>Email (optional)</label>
                  <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="john@example.com"
                    value="<%= activeEdit ? (activeEdit.email || '') : '' %>"
                  />
                </div>
                <div class="form-group">
                  <label>Gender (optional)</label>
                  <select name="gender" class="form-control">
                    <option value="unspecified" <%= !activeEdit || !activeEdit.gender || activeEdit.gender === 'unspecified' ? 'selected' : '' %>>Prefer not to say</option>
                    <option value="male" <%= activeEdit && activeEdit.gender === 'male' ? 'selected' : '' %>>Male</option>
                    <option value="female" <%= activeEdit && activeEdit.gender === 'female' ? 'selected' : '' %>>Female</option>
                    <option value="other" <%= activeEdit && activeEdit.gender === 'other' ? 'selected' : '' %>>Other</option>
                  </select>
                </div>
                <div class="flex gap-8">
                  <button type="submit" class="btn btn-primary" style="flex:1; justify-content:center;">
                    <% if (activeEdit) { %>
                      <i class="fa-solid fa-save"></i> Update Contact
                    <% } else { %>
                      <i class="fa-solid fa-plus"></i> Add Contact
                    <% } %>
                  </button>
                  <% if (activeEdit) { %>
                    <a href="/contacts" class="btn btn-outline">Cancel</a>
                  <% } %>
                </div>
              </form>
            </div>
          </div>

          <!-- Import CSV -->
          <div class="card">
            <div class="card-header">
              <h2><i class="fa-solid fa-file-csv" style="color:var(--success);margin-right:6px;"></i>Import CSV</h2>
            </div>
            <div class="card-body">
              <form action="/contacts/import" method="POST" enctype="multipart/form-data">
                <label class="file-upload" id="csvUploadLabel">
                  <i class="fa-solid fa-cloud-arrow-up"></i>
                  <p>Click to upload or drag & drop CSV</p>
                  <span class="text-sm text-muted">Max size: 5MB</span>
                  <input type="file" id="csvFile" name="csvFile" accept=".csv" required />
                </label>
                <div class="alert alert-info mt-8" style="font-size:12px;">
                  <div>
                    <strong>CSV Format:</strong><br/>
                    <code>name,phone,email,gender</code><br/>
                    <code>John,9876543210,john@example.com,male</code><br/>
                    <span class="text-muted">91 is auto-added if missing, and non-WhatsApp numbers are skipped.</span>
                  </div>
                </div>
                <button type="submit" class="btn btn-success btn-full mt-8">
                  <i class="fa-solid fa-file-import"></i> Import Contacts
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>