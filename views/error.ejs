<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="auth-page">
    <div style="text-align:center; padding: 48px 24px; max-width: 480px; margin: 0 auto;">
      <div style="font-size: 80px; font-weight: 800; color: var(--border); margin-bottom: 8px;">
        <%= code %>
      </div>
      <i class="fa-solid fa-triangle-exclamation" style="font-size:40px; color:var(--warning); margin-bottom:16px; display:block;"></i>
      <h1 style="font-size:22px; font-weight:700; margin-bottom:8px; color:var(--text);"><%= title %></h1>
      <p style="color:var(--text-secondary); margin-bottom:28px;"><%= message %></p>
      <div class="flex gap-8" style="justify-content:center;">
        <a href="/dashboard" class="btn btn-primary">
          <i class="fa-solid fa-gauge"></i> Go to Dashboard
        </a>
        <a href="javascript:history.back()" class="btn btn-outline">
          <i class="fa-solid fa-arrow-left"></i> Go Back
        </a>
      </div>
    </div>
  </div>
</body>
</html>